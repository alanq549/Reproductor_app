<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reproductor Simple"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnInternal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reproducir Audio Interno (RAW)"
        android:layout_marginBottom="10dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#CCCCCC"
        android:layout_marginVertical="20dp"/>

    <Button
        android:id="@+id/btnSelectSong1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar Canción 1"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/btnPlaySong1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reproducir Canción 1"
        android:enabled="false"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnSelectSong2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seleccionar Canción 2"
        android:layout_marginBottom="5dp"/>

    <Button
        android:id="@+id/btnPlaySong2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reproducir Canción 2"
        android:enabled="false"
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btnPause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PAUSE / STOP"
        android:backgroundTint="#FF5722"/>

</LinearLayout>
