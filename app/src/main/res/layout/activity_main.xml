<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pink_dark">

    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌸 Audios"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/pink_text"
            android:fontFamily="serif"/>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/pink_border"/>

    <LinearLayout
        android:id="@+id/tabsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#15080F"
        android:padding="10dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/tabAlarmas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp"
            android:background="@drawable/tab_active_bg">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔔"
                android:textSize="18sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alarmas"
                android:textSize="11sp"
                android:textColor="@color/pink_text"
                android:textStyle="bold"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabCancion"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="18sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Canción"
                android:textSize="11sp"
                android:textColor="@color/pink_muted"
                android:gravity="center"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tabPropia"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="10dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎤"
                android:textSize="18sp"
                android:gravity="center"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Propia"
                android:textSize="11sp"
                android:textColor="@color/pink_muted"
                android:gravity="center"/>
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="@color/pink_border"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/panelAlarmas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SONIDOS DEL SISTEMA"
                    android:textSize="10sp"
                    android:textColor="@color/pink_muted"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg_active"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_bg"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔔"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alarm_Classic"
                            android:textSize="13sp"
                            android:textColor="@color/pink_text"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RingtoneManager · 00:30"
                            android:textSize="11sp"
                            android:textColor="@color/pink_muted"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSystem"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:background="@drawable/play_btn_bg"
                        android:padding="0dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_bg"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏰"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alarm_Beep"
                            android:textSize="13sp"
                            android:textColor="@color/pink_text"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RingtoneManager · 00:15"
                            android:textSize="11sp"
                            android:textColor="@color/pink_muted"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSystem2"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:background="@drawable/play_btn_bg"
                        android:padding="0dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@drawable/card_bg"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/icon_bg"
                        android:gravity="center">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔊"
                            android:textSize="18sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Alarm_Gentle"
                            android:textSize="13sp"
                            android:textColor="@color/pink_text"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="RingtoneManager · 00:45"
                            android:textSize="11sp"
                            android:textColor="@color/pink_muted"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnSystem3"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="▶"
                        android:textSize="13sp"
                        android:textColor="@color/white"
                        android:background="@drawable/play_btn_bg"
                        android:padding="0dp"/>
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelCancion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/song_hero_bg"
                    android:padding="20dp"
                    android:gravity="center"
                    android:layout_marginBottom="14dp">

                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:background="@drawable/album_art_bg"
                        android:gravity="center"
                        android:layout_marginBottom="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎵"
                            android:textSize="36sp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mi Canción"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_text"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Desde almacenamiento local"
                        android:textSize="12sp"
                        android:textColor="@color/pink_accent"
                        android:layout_marginTop="3dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="12dp">

                        <Button
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="⏮"
                            android:textSize="16sp"
                            android:textColor="@color/pink_muted"
                            android:background="@android:color/transparent"
                            android:padding="0dp"/>

                        <Button
                            android:id="@+id/btnLocal"
                            android:layout_width="52dp"
                            android:layout_height="52dp"
                            android:text="▶"
                            android:textSize="20sp"
                            android:textColor="@color/white"
                            android:background="@drawable/play_main_bg"
                            android:padding="0dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginEnd="16dp"/>

                        <Button
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="⏭"
                            android:textSize="16sp"
                            android:textColor="@color/pink_muted"
                            android:background="@android:color/transparent"
                            android:padding="0dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelPropia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TU MÚSICA"
                    android:textSize="10sp"
                    android:textColor="@color/pink_muted"
                    android:letterSpacing="0.15"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/song_hero_bg"
                    android:padding="24dp"
                    android:gravity="center">

                    <FrameLayout
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@drawable/album_art_bg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="📂"
                            android:textSize="40sp" />

                        <Button
                            android:id="@+id/btnSelect"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="@android:color/transparent" />
                    </FrameLayout>

                    <TextView
                        android:id="@+id/txtSelectedSong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toca para elegir un archivo"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/pink_text"
                        android:gravity="center"
                        android:paddingHorizontal="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Almacenamiento del dispositivo"
                        android:textSize="11sp"
                        android:textColor="@color/pink_muted"
                        android:layout_marginTop="4dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="24dp">

                        <ProgressBar
                            android:id="@+id/progressExternal"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="4dp"
                            android:layout_weight="1"
                            android:progress="0"
                            android:progressTint="@color/pink_accent"
                            android:progressBackgroundTint="@color/pink_border"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:id="@+id/txtDuration"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0:00"
                            android:textSize="10sp"
                            android:textColor="@color/pink_muted" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginTop="20dp">

                        <Button
                            android:id="@+id/btnExternal"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="▶"
                            android:textSize="22sp"
                            android:textColor="@color/white"
                            android:background="@drawable/play_main_bg"
                            android:padding="0dp"/>

                        <Button
                            android:id="@+id/btnPause"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:text="⏸"
                            android:textSize="22sp"
                            android:textColor="@color/white"
                            android:background="@drawable/play_main_bg"
                            android:padding="0dp"
                            android:layout_marginStart="16dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
